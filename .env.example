# Frontend environment for Vite/Vercel
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Leave empty for local Vite proxy. Set to your Render backend origin in Vercel.
# Example: https://civic-track-api.onrender.com
VITE_API_ORIGIN=

# Optional. If empty, the app uses VITE_API_ORIGIN for Socket.IO.
VITE_SOCKET_URL=
